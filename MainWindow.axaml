<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        xmlns:controls="clr-namespace:Diorama.UI.Controls"
        x:Class="Diorama.MainWindow"
        DragDrop.AllowDrop="True" DragDrop.Drop="Window_DragDrop"
        Title="Diorama">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Menu Grid.Row="0" BorderBrush="#ff404040" BorderThickness="0,0,0,1">
      <MenuItem Header="_File">
        
      </MenuItem>
    </Menu>
    
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="3" />
        <ColumnDefinition Width="2*" />
      </Grid.ColumnDefinitions>

      <!-- editor panels go here -->
      
      <GridSplitter Grid.Column="1"
                    Width="3"
                    Background="#444"
                    ResizeDirection="Columns"
                    HorizontalAlignment="Stretch"/>
      <controls:ViewportNewControl x:Name="MainViewport" Grid.Column="2"/>
    
    </Grid>
  </Grid>
</Window>
