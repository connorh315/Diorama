<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Diorama.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
    <Application.Resources>
      <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
          <ResourceInclude Source="/UI/Controls/SceneHierarchy.axaml"/>
          <ResourceInclude Source="/UI/Controls/Vec3Input.axaml"/>
          
          <ResourceInclude Source="/UI/Panels/InspectorPanel.axaml"/>
          <ResourceInclude Source="/UI/Panels/ClipObjectPanel.axaml"/>
        </ResourceDictionary.MergedDictionaries>
      </ResourceDictionary>
    </Application.Resources>
</Application>