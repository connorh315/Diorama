<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        xmlns:controls="clr-namespace:Diorama.UI.Controls"
        x:Class="Diorama.MainWindow"
        DragDrop.AllowDrop="True" DragDrop.Drop="Window_DragDrop"
        Title="Diorama"
        Focusable="True">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Menu Grid.Row="0" BorderBrush="#ff404040" BorderThickness="0,0,0,1">
      <MenuItem Header="_File">
        <MenuItem Header="Open" Click="OpenFile_Click"/>
      </MenuItem>
      <MenuItem Header="Toggle Lightmaps" Click="LightmapItem_Click" />
      <MenuItem Header="Toggle Camera Lighting" Click="CameraLightItem_Click" />
    </Menu>
    
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="3" />
        <ColumnDefinition Width="2*" />
      </Grid.ColumnDefinitions>

      <Grid Grid.Column="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="2*" />
          <RowDefinition Height="3" />
          <RowDefinition Height="1*" />
          <RowDefinition Height="3" />
          <RowDefinition Height="2*" />
        </Grid.RowDefinitions>
        <ContentControl x:Name="HierarchyHost" Grid.Row="0" />
        <GridSplitter Grid.Row="1"
                    Height="3"
                    Background="#444"
                    ResizeDirection="Rows"
                    VerticalAlignment="Stretch"/>
        <ContentControl x:Name="InspectorHost" Grid.Row="2" />
        <GridSplitter Grid.Row="3"
                    Height="3"
                    Background="#444"
                    ResizeDirection="Rows"
                    VerticalAlignment="Stretch"/>
        <ContentControl x:Name="GeometryHost" Grid.Row="4" />
        
      </Grid>
      
      <GridSplitter Grid.Column="1"
                    Width="3"
                    Background="#444"
                    ResizeDirection="Columns"
                    HorizontalAlignment="Stretch"/>
      <ContentControl x:Name="ViewportHost" Grid.Column="2" />
    
    </Grid>
  </Grid>
</Window>
